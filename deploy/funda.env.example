# Funda box environment — copy to ~/.config/funda/funda.env on the maylenovo box.
# Read by all funda-*.service units via EnvironmentFile. Values are LITERAL
# (systemd does not expand $HOME / %h here) — use absolute paths.

# Project / deploy directory (where the repo is cloned on the box).
FUNDA_PROJECT=/home/may/house

# Make user-local CLIs (claude, codex, node) discoverable to the bot + gmail sync.
PATH=/home/may/.local/bin:/usr/local/bin:/usr/bin:/bin

# Explicit binaries (optional — gmail-sync.sh auto-detects `claude` on PATH if unset).
CLAUDE_BIN=/home/may/.local/bin/claude

# Display for the Playwright auto-applier (headed real Chrome on the GNOME session).
DISPLAY=:0
XAUTHORITY=/home/may/.Xauthority
